# Docker Compose service ports
API_PORT=8000
POSTGRES_PORT=15432
REDIS_PORT=16379

# PostgreSQL container bootstrap
POSTGRES_USER=diagent
POSTGRES_PASSWORD=diagent
POSTGRES_DB=diagent

# App service URLs used inside Docker Compose
DATABASE_URL=postgresql+asyncpg://diagent:diagent@postgres:5432/diagent
REDIS_URL=redis://redis:6379/0
# Host machine'den çalıştırırken: http://localhost:8000
# docker compose exec CONTAINER python -m scripts... çalıştırırken:
#   api container'ında çalıştır (exec api), worker'da değil
# Worker servisi docker-compose.yml'de http://api:8000 olarak override edilir
DIAGENT_API_URL=http://localhost:8000

# Judge LLM backend: openai or ollama
DIAGENT_JUDGE_BACKEND=openai
JUDGE_RATE_LIMIT_SECONDS=1

# OpenAI judge settings
OPENAI_API_KEY=
OPENAI_JUDGE_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama judge settings
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_JUDGE_MODEL=llama3.1

# Rule-based anomaly detector thresholds
TOOL_LOOP_THRESHOLD=3
COST_SPIKE_MULTIPLIER=5.0
LATENCY_SPIKE_MS=30000
STALE_DATA_HOURS=72.0
TOOL_FAILURE_RATE=0.5
# Note: PathFinder-Ship (Step 9) uses a local model — cost_usd is typically 0.
# Its primary anomaly signal is LATENCY_SPIKE_MS, not COST_SPIKE_MULTIPLIER.

# Diagnostician trigger threshold
DIAGNOSIS_RAG_SCORE_THRESHOLD=0.6

# Worker logging
CELERY_LOG_LEVEL=info
